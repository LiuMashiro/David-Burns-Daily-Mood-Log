/* app.wxss */
page {
  /* Apple iOS Human Interface Guidelines Colors */
  --ios-blue: #007AFF;
  --ios-green: #34C759;
  --ios-red: #FF3B30;
  --ios-orange: #FF9500;
  
  --ios-bg-color: #F2F2F7;
  --ios-card-bg: #FFFFFF;
  
  --ios-text-primary: #000000;
  --ios-text-secondary: rgba(60, 60, 67, 0.6);
  --ios-text-tertiary: rgba(60, 60, 67, 0.3);
  
  --ios-input-bg: rgba(118, 118, 128, 0.08);
  --ios-border-color: rgba(60, 60, 67, 0.1);
  
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
  background-color: var(--ios-bg-color);
  color: var(--ios-text-primary);
  font-size: 16px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

view, text, scroll-view, textarea, input, button, slider {
  box-sizing: border-box !important;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}