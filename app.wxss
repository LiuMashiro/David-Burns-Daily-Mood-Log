/* app.wxss */
page {
  /* 全局浅色模式色彩变量 */
  --app-blue: #007AFF;
  --app-green: #4CAF50; /* 调整为更温暖的绿色 */
  --app-red: #FF3B30;
  --app-orange: #FF9500;
  
  --app-bg-color: #F2F2F7;
  --app-card-bg: #FFFFFF;
  
  --app-text-primary: #000000;
  --app-text-secondary: rgba(60, 60, 67, 0.6);
  --app-text-tertiary: rgba(60, 60, 67, 0.3);
  
  --app-input-bg: rgba(118, 118, 128, 0.08);
  --app-border-color: rgba(60, 60, 67, 0.1);
  
  /* 调整半透明度与模糊 */
  --app-glass-bg: rgba(242, 242, 247, 0.65);
  --app-panel-bg: rgba(255, 255, 255, 0.75);
  
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
  background-color: var(--app-bg-color);
  color: var(--app-text-primary);
  font-size: 16px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

@media (prefers-color-scheme: dark) {
  page {
    --app-blue: #0A84FF;
    --app-green: #66BB6A; /* 调整为更温暖的绿色 */
    --app-red: #FF453A;
    --app-orange: #FF9F0A;
    
    --app-bg-color: #000000;
    --app-card-bg: #1C1C1E;
    
    --app-text-primary: #FFFFFF;
    --app-text-secondary: rgba(235, 235, 245, 0.6);
    --app-text-tertiary: rgba(235, 235, 245, 0.3);
    
    --app-input-bg: rgba(118, 118, 128, 0.24);
    --app-border-color: rgba(84, 84, 88, 0.65);
    
    --app-glass-bg: rgba(0, 0, 0, 0.65);
    --app-panel-bg: rgba(28, 28, 30, 0.75);
  }
}

view, text, scroll-view, textarea, input, button, slider {
  box-sizing: border-box !important;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 全局动画增强 */
.pop-in { animation: popIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) both; }
@keyframes popIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}